# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; `example.env` is committed as a template.
# ─────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────
# Supabase — safe to expose to the browser
# Get from: Supabase project → Settings → API
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────
# Supabase service role — server-side only, never sent to browser
# Bypasses RLS. Treat like a root password.
# ─────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# Admin dashboard password (used at /admin)
# ─────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-to-a-strong-password

# ─────────────────────────────────────────────────────────────
# HMAC secret for customer + driver session cookies
# Generate with: openssl rand -hex 64
# ─────────────────────────────────────────────────────────────
AUTH_JWT_SECRET=replace-with-a-long-random-secret-at-least-64-chars

# ─────────────────────────────────────────────────────────────
# HMAC secret for admin dashboard session cookies
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=replace-with-a-random-secret-at-least-32-chars

# ─────────────────────────────────────────────────────────────
# Canonical site URL (used for OAuth callbacks & password-reset links)
# Local dev:  http://localhost:3000
# Production: https://yourdomain.com
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Google OAuth — optional; enables "Sign in with Google"
# Get from: Google Cloud Console → APIs & Services → Credentials
# Leave blank to disable Google sign-in
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────
# Postgres connection string — only needed for `npm run db:migrate`
# (initial database setup). The app itself doesn't use this.
# Get from: Supabase Dashboard → Connect → Direct (or Session pooler)
# Special chars in the password MUST be URL-encoded.
# Example: postgresql://postgres.<ref>:<encoded-pw>@<host>:5432/postgres
# ─────────────────────────────────────────────────────────────
DATABASE_URL=


# ─────────────────────────────────────────────────────────────
# NOTE: SMTP and Stripe/PayPal credentials are NOT set here.
# They are entered through Admin → Integrations and stored in
# the `app_settings` table. They never reach the browser.
# ─────────────────────────────────────────────────────────────
